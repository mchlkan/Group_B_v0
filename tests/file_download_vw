class OWIDDataset:
    BASE_URL = "https://ourworldindata.org/grapher/"

    def __init__(self, slug: str):
        self.slug = slug  # the part of the URL identifying the dataset
        self.df = None
        self.metadata = None
        self._fetch()

    def _build_urls(self):
        params = "?v=1&csvType=full&useColumnShortNames=true"
        csv_url = f"{self.BASE_URL}{self.slug}.csv{params}"
        meta_url = f"{self.BASE_URL}{self.slug}.metadata.json{params}"
        return csv_url, meta_url

    def _fetch(self):
        csv_url, meta_url = self._build_urls()
        print(f"Fetching {self.slug}...")
        self.df = pd.read_csv(csv_url, storage_options={"User-Agent": "Our World In Data data fetch/1.0"})
        self.metadata = requests.get(meta_url).json()
        print(f"  ✓ Loaded {self.df.shape[0]} rows, {self.df.shape[1]} columns")

    def summary(self):
        print(f"\n=== {self.slug} ===")
        print(self.df.info())


class OWIDCollection:
    DATASETS = {
        "forest": "annual-change-forest-area",
        "deforestation": "annual-deforestation",
        "forest_landmass": "forest-area-as-share-of-land-area",
    }

    def __init__(self):
        self.datasets = {}
        for name, slug in self.DATASETS.items():
            self.add(slug, name=name)

    def add(self, slug: str, name: str | None = None):
        key = name or slug
        dataset = OWIDDataset(slug)
        self.datasets[key] = dataset
        # Set the dataset as an attribute on the collection
        attr_name = key.strip().lower().replace(" ", "_").replace("-", "_")
        setattr(self, attr_name, dataset)
        return self

    def __getitem__(self, key):
        return self.datasets[key]

    def __repr__(self):
        return f"OWIDCollection({list(self.datasets.keys())})"

    def summary(self):
        for dataset in self.datasets.values():
            dataset.summary()

    def heads(self, n=5):
        for name, dataset in self.datasets.items():
            print(f"\n=== {name} ===")
            print(dataset.df.head(n))


